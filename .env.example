# Resend API Key — get one at https://resend.com/api-keys
RESEND_API_KEY=re_api_key_goes_here

# The "from" email address (must be from a verified Resend domain)
# If you haven't set up a custom domain, use: onboarding@resend.dev
FROM_EMAIL=onboarding@resend.dev

# The email address where you want to receive enquiries
TO_EMAIL=user_email_goes_here

# The email address you want to send automated responses from
RESPONSE_MAIL = NOREPLY MAIL ID GOES HERE
